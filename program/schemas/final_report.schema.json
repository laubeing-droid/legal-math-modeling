{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinalReport",
  "type": "object",
  "required": ["run_id", "program_status", "repository_commits", "track_results"],
  "properties": {
    "run_id": {"type": "string"},
    "finished_at": {"type": "string"},
    "program_status": {"enum": ["NIGHT_RUN_COMPLETE", "NIGHT_RUN_PARTIAL", "FORMAL_CORE_RELEASED_BANACH_BLOCKED", "PRODUCTION_ASSURANCE_BLOCKED", "FAILED"]},
    "repository_commits": {
      "type": "object",
      "properties": {
        "legal-math-modeling": {"type": "string"},
        "juris-calculus": {"type": "string"},
        "deli-autoresearch": {"type": "string"}
      }
    },
    "track_results": {
      "type": "object",
      "properties": {
        "A": {"$ref": "#/$defs/track_result"},
        "B": {"$ref": "#/$defs/track_result"},
        "C": {"$ref": "#/$defs/track_result"},
        "D": {"$ref": "#/$defs/track_result"},
        "E": {"$ref": "#/$defs/track_result"}
      }
    },
    "remaining_blockers": {"type": "array", "items": {"type": "string"}},
    "next_runnable_tasks": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "track_result": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "theorem_count": {"type": "integer"},
        "sorry_count": {"type": "integer"},
        "test_count": {"type": "integer"},
        "test_passed": {"type": "integer"},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
